# ---- API keys ------------------------------------------------------------
# ANTHROPIC_API_KEY is required (the chat default and a few internal calls
# still run on Anthropic). OPENAI_API_KEY is required if any purpose in
# DEFAULT_MODEL_BY_PURPOSE resolves to a gpt-* model — which it does by
# default (Scenario D in v0.8.0: cheap OpenAI mini-class for everything
# internal). Pure-Anthropic deployments can omit OPENAI_API_KEY by
# overriding the gpt-* purposes via AEDOS_MODEL_<purpose>=claude-*.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

AEDOS_DB_PATH=aedos.db

# ---- Chat-slot model -----------------------------------------------------
# The CHAT model is the one under test — the assistant draft model whose
# claims get extracted and routed. The chat UI no longer has a model
# dropdown; this env var is the only way to override the default
# (claude-haiku-4-5). Set it to claude-opus-4-7 / claude-sonnet-4-6 /
# any gpt-* id when you want a different model under test.
AEDOS_CHAT_MODEL=claude-haiku-4-5
# Optional cap on tokens in the chat reply.
# AEDOS_CHAT_MAX_TOKENS=1024

# ---- Per-purpose model overrides (advanced) -----------------------------
# Every internal LLM call carries a `purpose` tag. The dispatcher resolves
# it through DEFAULT_MODEL_BY_PURPOSE (in src/llm_client.py). Override any
# entry by setting AEDOS_MODEL_<purpose>. The model name's prefix
# (claude-* vs gpt-*) selects the provider's SDK.
#
# Defaults (Scenario D):
#   chat                → claude-haiku-4-5   (override only via AEDOS_CHAT_MODEL)
#   extractor:user      → gpt-4.1-mini
#   extractor:assistant → gpt-4.1-mini
#   router              → gpt-4.1-mini
#   cache_classify      → gpt-4.1-nano
#   prompt_builder      → gpt-4.1-mini
#   code_writer         → gpt-4.1-mini
#   retrieval_judge     → gpt-4.1-mini
#   corrector           → gpt-4.1-mini
#
# Examples:
# AEDOS_MODEL_extractor:user=claude-haiku-4-5
# AEDOS_MODEL_router=claude-sonnet-4-6
# AEDOS_MODEL_code_writer=claude-sonnet-4-6

# ---- Legacy three-role overrides ----------------------------------------
# Predates the per-purpose dispatcher. Still honoured as a fallback when
# a purpose is unknown to DEFAULT_MODEL_BY_PURPOSE. Leave unset unless
# you specifically want a single Anthropic model for all extractor /
# corrector fallbacks.
# AEDOS_EXTRACTOR_MODEL=
# AEDOS_CORRECTOR_MODEL=

# ---- Retrieval verifier --------------------------------------------------
# v0.7.15 collapsed retrieval to Wikipedia-only (no Tavily, SerpAPI, or
# DuckDuckGo). The cache TTL below is the per-query result cache for
# the Wikipedia REST calls — distinct from the Tier 2 verification cache.
AEDOS_RETRIEVAL_CACHE_TTL_HOURS=24

# ---- v0.6 Tier 2 verification cache --------------------------------------
# The cache is always on. Every assistant turn runs the cache classifier
# (one combined call: decides eligibility + TTL), and writes successful
# retrieval verdicts; subsequent equivalent claims hit the cache instead
# of re-running retrieval. Inspect it via the Cache tab in the trace UI
# or /api/cache. There is no env-var to disable it.

# ---- v0.6 PROTOTYPE: unique-value-slot detection (off by default) ---------
# Catches the 'user born in MA in turn N, then says born in VA in turn M'
# adversarial pattern. When enabled, the router checks whether a new user
# assertion contradicts a prior user assertion on a slot that's
# biologically/definitionally unique per entity (currently just
# spatial_temporal.was_born_in). Outcome is user_contradicted_self.
# Review src/router.py's _UNIQUE_VALUE_SLOTS map before enabling.
AEDOS_UNIQUE_VALUE_SLOTS=
