# Aedos v0.15 — environment configuration.
#
# Copy this file to `.env` and fill in your API keys. `scripts/reset_db.py`
# loads `.env` automatically; for the server and the evaluation harnesses,
# export these variables or pass them on the command line
# (e.g. `uvicorn aedos.app:app --env-file .env`).

# ---- API keys ------------------------------------------------------------
# ANTHROPIC_API_KEY is required — the chat slot defaults to an Anthropic model
# (claude-haiku-4-5).
# OPENAI_API_KEY is required by default — substrate-oracle, extraction, walker,
# and Python-verifier calls default to gpt-* models. A pure-Anthropic
# deployment can omit OPENAI_API_KEY by routing every gpt-* purpose to a
# claude-* model via AEDOS_MODEL_<purpose> (see "Model routing" below).
# OPENROUTER_API_KEY is required only if a purpose is routed to OpenRouter
# (an OpenAI-API-compatible host for open-weight models — used by the Phase E
# model comparison, and by any purpose migrated to an open-weight model).
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# ---- Database ------------------------------------------------------------
# Path to the SQLite database file. Defaults to aedos.db.
AEDOS_DB_PATH=aedos.db

# ---- Model routing -------------------------------------------------------
# Each internal LLM call carries a `purpose` tag. `DEFAULT_MODEL_BY_PURPOSE`
# (src/aedos/llm/client.py) maps every purpose to a full routing config —
# {model, base_url, api_key_env_var}. Routing is explicit: base_url None routes
# to the native Anthropic SDK; a URL routes to the OpenAI-compatible SDK
# (OpenAI, OpenRouter, or any compatible host) pointed at that endpoint.
#
# Built-in per-purpose defaults (model | endpoint):
#   chat                              claude-haiku-4-5 | Anthropic
#   extractor:user                    gpt-4.1-mini     | OpenAI
#   extractor:assistant               gpt-4.1          | OpenAI
#   substrate:predicate_translation   gpt-4.1-mini     | OpenAI
#   substrate:subsumption             gpt-4.1-mini     | OpenAI
#   substrate:predicate_distribution  gpt-4.1-mini     | OpenAI
#   substrate:entity_resolution       gpt-4.1-mini     | OpenAI
#   python_verifier                   gpt-4.1-mini     | OpenAI
#   walker                            gpt-4.1-mini     | OpenAI
#
# Override the chat-slot model (provider inferred from the model name):
# AEDOS_CHAT_MODEL=claude-haiku-4-5
#
# Override one purpose's model — AEDOS_MODEL_ + the exact purpose tag. This is
# a model-only override; the provider is inferred from the model-name prefix
# (gpt-/o1-/o3-/o4- -> OpenAI, otherwise Anthropic). To route a purpose to
# OpenRouter (or any non-default endpoint), set its full config in
# DEFAULT_MODEL_BY_PURPOSE rather than via AEDOS_MODEL_<purpose>:
# AEDOS_MODEL_walker=claude-haiku-4-5
# AEDOS_MODEL_python_verifier=gpt-4.1

# ---- Testing / evaluation gates (opt-in) ---------------------------------
# The test suite runs fully mocked by default — no API keys, no network. These
# gates enable the live paths; see README.md and docs/phase_10_5_runbook.md.
#   RUN_LIVE_KB=1      the Wikidata adapter makes live SPARQL / search calls
#   RUN_LIVE_TESTS=1   enables tests that make live LLM / live KB calls
#   RUN_CALIBRATION=1  runs the calibration corpora against live services
# RUN_LIVE_KB=1
# RUN_LIVE_TESTS=1
# RUN_CALIBRATION=1
