ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides for the THREE Anthropic-bound roles:
#   AEDOS_EXTRACTOR_MODEL — used for extract_with_tool calls (extractor +
#                            scoping classifier + stability classifier
#                            + code prompt builder).
#   AEDOS_CORRECTOR_MODEL — used for rewrite calls (corrector + code
#                            writer + retrieval judge). The cross-check
#                            forces Sonnet 4.6 here regardless (see
#                            CROSS_CHECK_MODEL in code_generation/pipeline).
#   AEDOS_CHAT_MODEL      — used by the AnthropicChatBackend WHEN
#                            AEDOS_CHAT_MODEL_PROVIDER=anthropic.
#                            Ignored when provider=modal.
#
# Defaults to claude-opus-4-7 for all three. Sonnet 4.6 is a cheaper
# choice for extractor + corrector if iterating fast. Haiku 4.5 works
# for the corrector model since it's also the retrieval judge.
AEDOS_DB_PATH=aedos.db
AEDOS_EXTRACTOR_MODEL=claude-opus-4-7
AEDOS_CHAT_MODEL=claude-opus-4-7
AEDOS_CORRECTOR_MODEL=claude-opus-4-7

# ---- Chat model under test ------------------------------------------------
# AEDOS verifies the *chat model* — the one that generates assistant drafts
# whose claims are extracted and routed. The infrastructure LLMs (extractor,
# router, code-writer, judge, corrector) ALWAYS use Anthropic regardless of
# this setting. Only the chat role is pluggable.
#
#   anthropic (default) — use AEDOS_CHAT_MODEL on the Anthropic API
#   modal               — use GLM-5.1-FP8 served by Modal (see MODAL_API_KEY)
#
AEDOS_CHAT_MODEL_PROVIDER=anthropic

# Maximum tokens for the chat backend's response. Per-backend defaults
# below; AEDOS_CHAT_MAX_TOKENS (unset by default) overrides both.
#
#   * Anthropic chat (no reasoning_content): 1024 is ample for short
#     conversational answers.
#   * Modal/GLM (reasoning model — burns tokens on reasoning_content
#     BEFORE emitting user-visible content): 4096 leaves headroom for
#     a typical reasoning chain plus a substantive answer. With 1024
#     GLM truncates to content=null on hard prompts (e.g. spell
#     'floccinaucinihilipilification' backwards — turn 4 of the
#     hallucination corpus did this).
#
# Trade-off: higher cap = longer requests = more cold-start risk on Modal.
#
# AEDOS_CHAT_MAX_TOKENS=                 # global override; wins over both below
AEDOS_CHAT_MAX_TOKENS_ANTHROPIC=1024
AEDOS_CHAT_MAX_TOKENS_MODAL=4096

# Modal-hosted GLM-5.1-FP8 endpoint. Free until 2026-04-30; after that,
# switch AEDOS_CHAT_MODEL_PROVIDER back to anthropic and document in
# autonomous_state/DECISIONS.md.
#
# Endpoint:
#   https://api.us-west-2.modal.direct/v1/chat/completions
#
# Request shape (OpenAI-compatible):
#   curl -X POST "https://api.us-west-2.modal.direct/v1/chat/completions" \
#     -H "Content-Type: application/json" \
#     -H "Authorization: Bearer <MODAL_API_KEY>" \
#     -d '{"model": "zai-org/GLM-5.1-FP8",
#          "messages": [{"role": "user", "content": "..."}],
#          "max_tokens": 500}'
#
# Set MODAL_API_KEY only if AEDOS_CHAT_MODEL_PROVIDER=modal.
MODAL_API_KEY=

# Retrieval verifier
# By default, retrieval uses DuckDuckGo's HTML endpoint (no API key required,
# can be flaky). If a key for one of these providers is set, it is preferred.
TAVILY_API_KEY=
SERPAPI_KEY=
# Cache TTL for retrieval results (the per-DDG-query result cache), in
# hours. Default 24. NOT the same as the v0.6 verification cache below.
AEDOS_RETRIEVAL_CACHE_TTL_HOURS=24

# ---- v0.6 Tier 2 verification cache --------------------------------------
# The cache is always on. Every assistant turn runs the scoping
# classifier (decides cache eligibility), the stability classifier
# (decides TTL), and writes successful retrieval verdicts to the cache;
# subsequent equivalent claims hit the cache instead of re-running
# retrieval. The cache should accumulate across sessions — that's the
# whole point. There is no env-var to disable it.
#
# Inspect cache contents and live hit rate with the Cache tab in the
# trace UI or via /api/cache.

# ---- v0.6 PROTOTYPE: unique-value-slot detection (off by default) ---------
# Catches the 'user born in MA in turn N, then says born in VA in turn M'
# adversarial pattern (corpus turn 26 'BIG MISS'). When enabled, the
# router checks whether a new user assertion contradicts a prior user
# assertion on a slot that's biologically/definitionally unique per
# entity (currently just spatial_temporal.was_born_in). Outcome is
# user_contradicted_self.
#
# Architectural change — operator should review src/router.py's
# _UNIQUE_VALUE_SLOTS map before enabling for production. Currently
# only one entry: spatial_temporal.was_born_in (entity → location).
#
# When OFF, the router uses the v0.3+ default contradiction model
# (polarity-flip only) and ignores this check entirely.
AEDOS_UNIQUE_VALUE_SLOTS=
