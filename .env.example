ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides for the THREE Anthropic-bound roles:
#   AEDOS_EXTRACTOR_MODEL — used for extract_with_tool calls (extractor +
#                            scoping classifier + stability classifier
#                            + code prompt builder).
#   AEDOS_CORRECTOR_MODEL — used for rewrite calls (corrector + code
#                            writer + retrieval judge). The cross-check
#                            forces Sonnet 4.6 here regardless (see
#                            CROSS_CHECK_MODEL in code_generation/pipeline).
#   AEDOS_CHAT_MODEL      — used by the AnthropicChatBackend WHEN
#                            AEDOS_CHAT_MODEL_PROVIDER=anthropic.
#                            Ignored when provider=modal.
#
# Defaults to claude-opus-4-7 for all three. Sonnet 4.6 is a cheaper
# choice for extractor + corrector if iterating fast. Haiku 4.5 works
# for the corrector model since it's also the retrieval judge.
AEDOS_DB_PATH=aedos.db
AEDOS_EXTRACTOR_MODEL=claude-opus-4-7
AEDOS_CHAT_MODEL=claude-opus-4-7
AEDOS_CORRECTOR_MODEL=claude-opus-4-7

# ---- Chat model under test ------------------------------------------------
# AEDOS verifies the *chat model* — the one that generates assistant drafts
# whose claims are extracted and routed. The infrastructure LLMs (extractor,
# router, code-writer, judge, corrector) ALWAYS use Anthropic regardless of
# this setting. Only the chat role is pluggable.
#
#   anthropic (default) — use AEDOS_CHAT_MODEL on the Anthropic API
#   modal               — use GLM-5.1-FP8 served by Modal (see MODAL_API_KEY)
#
AEDOS_CHAT_MODEL_PROVIDER=anthropic

# Maximum tokens for the chat backend's response. Default 1024.
# Increase if you're prompting reasoning models (GLM-5.1, etc.) for
# long-output answers — those models spend tokens on reasoning_content
# before producing the user-visible content, and a low cap can cause
# truncation (response.content=null) on prompts that legitimately need
# a long answer (e.g. 'spell antidisestablishmentarianism backwards').
# Trade-off: higher cap = longer requests = more cold-start risk on Modal.
AEDOS_CHAT_MAX_TOKENS=1024

# Modal-hosted GLM-5.1-FP8 endpoint. Free until 2026-04-30; after that,
# switch AEDOS_CHAT_MODEL_PROVIDER back to anthropic and document in
# autonomous_state/DECISIONS.md.
#
# Endpoint:
#   https://api.us-west-2.modal.direct/v1/chat/completions
#
# Request shape (OpenAI-compatible):
#   curl -X POST "https://api.us-west-2.modal.direct/v1/chat/completions" \
#     -H "Content-Type: application/json" \
#     -H "Authorization: Bearer <MODAL_API_KEY>" \
#     -d '{"model": "zai-org/GLM-5.1-FP8",
#          "messages": [{"role": "user", "content": "..."}],
#          "max_tokens": 500}'
#
# Set MODAL_API_KEY only if AEDOS_CHAT_MODEL_PROVIDER=modal.
MODAL_API_KEY=

# Retrieval verifier
# By default, retrieval uses DuckDuckGo's HTML endpoint (no API key required,
# can be flaky). If a key for one of these providers is set, it is preferred.
TAVILY_API_KEY=
SERPAPI_KEY=
# Cache TTL for retrieval results (the per-DDG-query result cache), in
# hours. Default 24. NOT the same as the v0.6 verification cache below.
AEDOS_RETRIEVAL_CACHE_TTL_HOURS=24

# ---- v0.6 Tier 2 verification cache (off by default) ----------------------
# Three knobs in increasing order of effect. Each requires an extra LLM
# call per assistant claim, so opt-in. See ARCHITECTURE.md "Verification
# cache" for the full design.
#
#   AEDOS_CACHE_SCOPING=1   — enables the scoping classifier in
#                              OBSERVATION mode (logs cache_scoping_decision
#                              events; doesn't gate caching). Use this
#                              alone for one or two sessions to see what
#                              the classifier produces on real claims.
#
#   AEDOS_CACHE_STABILITY=1 — adds the TTL classifier (also observation
#                              mode). Only fires for claims scoping
#                              marked world_fact. No effect without
#                              AEDOS_CACHE_SCOPING.
#
#   AEDOS_CACHE_WRITES=1    — wires actual cache reads/writes. Cache
#                              hit short-circuits retrieval; cache write
#                              fills the table after a successful
#                              retrieval verdict. No effect without
#                              both above set.
#
# Inspect with the Cache tab in the trace UI or via /api/cache.
AEDOS_CACHE_SCOPING=
AEDOS_CACHE_STABILITY=
AEDOS_CACHE_WRITES=
