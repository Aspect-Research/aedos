ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides. Defaults to claude-opus-4-7 for all three.
# Sonnet (claude-sonnet-4-6) is a reasonable cheaper choice for the extractor
# and corrector if you're iterating fast. Haiku (claude-haiku-4-5) is fine for
# the corrector model since it's also used as the retrieval judge.
AEDOS_DB_PATH=aedos.db
AEDOS_EXTRACTOR_MODEL=claude-opus-4-7
AEDOS_CHAT_MODEL=claude-opus-4-7
AEDOS_CORRECTOR_MODEL=claude-opus-4-7

# Retrieval verifier
# By default, retrieval uses DuckDuckGo's HTML endpoint (no API key required,
# can be flaky). If a key for one of these providers is set, it is preferred.
TAVILY_API_KEY=
SERPAPI_KEY=
# Cache TTL for retrieval results, in hours. Default 24.
AEDOS_RETRIEVAL_CACHE_TTL_HOURS=24
