# ---- Required: API keys --------------------------------------------------
# ANTHROPIC_API_KEY is required (the chat slot defaults to Anthropic).
# OPENAI_API_KEY is required when any purpose in DEFAULT_MODEL_BY_PURPOSE
# resolves to a gpt-* model — which it does by default. Pure-Anthropic
# deployments can omit OPENAI_API_KEY by overriding the gpt-* purposes
# via AEDOS_MODEL_<purpose>=claude-*.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---- Database ------------------------------------------------------------
AEDOS_DB_PATH=aedos.db

# ---- Layer 5: decision threshold ----------------------------------------
# T splits hard verdicts (decision_confidence >= T) from soft verdicts
# (< T → hedge / fall-through). decision_confidence is the three-factor
# product path_prior × chain_reliability × evidence_strength. Default 0.5.
# AEDOS_DECISION_THRESHOLD=0.5

# ---- Per-purpose model routing ------------------------------------------
# Every internal LLM call carries a `purpose` tag. The dispatcher in
# src/llm_client.py resolves each purpose via DEFAULT_MODEL_BY_PURPOSE.
# Override any entry by setting AEDOS_MODEL_<purpose>=<model_id>; the
# model name's prefix (claude-* vs gpt-*) selects the provider.
#
# Defaults:
#   chat                  → claude-haiku-4-5
#   extractor:user        → gpt-4.1-mini
#   extractor:assistant   → gpt-4.1-mini
#   router                → gpt-4.1-mini
#   prompt_builder        → gpt-4.1-mini
#   code_writer           → gpt-4.1-mini
#   retrieval_judge       → gpt-4.1-mini
#   corrector             → gpt-4.1-mini
#   cache_classify        → gpt-4.1-nano
#   cache_scoping         → gpt-4.1-nano
#   cache_stability       → gpt-4.1-nano
#
# Examples:
# AEDOS_MODEL_router=claude-haiku-4-5
# AEDOS_MODEL_code_writer=claude-sonnet-4-6

# Chat-slot override (the model whose claims get extracted + verified).
# AEDOS_CHAT_MODEL=claude-haiku-4-5

# Fallback overrides for the extractor / corrector model fields when a
# purpose is unknown to DEFAULT_MODEL_BY_PURPOSE. Leave unset unless you
# specifically want a single Anthropic model for those fallbacks.
# AEDOS_EXTRACTOR_MODEL=
# AEDOS_CORRECTOR_MODEL=

# ---- Retrieval verifier --------------------------------------------------
# Per-query Wikipedia snippet cache TTL. Distinct from Tier W
# (verification_cache) — this is just the search-result cache so
# repeated identical queries during a single test run don't re-fetch.
# AEDOS_RETRIEVAL_CACHE_TTL_HOURS=24

# ---- Server port ---------------------------------------------------------
# Used by `python -m src.app`. Defaults to 8000.
# AEDOS_PORT=8000

# ---- Prototype: unique-value-slot detection (off by default) -------------
# Catches the "user born in MA in turn N, then says born in VA in turn M"
# adversarial pattern. When enabled (=1), Layer 2 checks whether a new
# user assertion contradicts a prior assertion on a slot that's
# definitionally unique per entity. Review
# src/layer2_routing/constants.py UNIQUE_VALUE_SLOTS before enabling.
# AEDOS_UNIQUE_VALUE_SLOTS=
