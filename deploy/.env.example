# Aedos v0.16.2 deployment — environment template.
# Copy to a real environment (process env / your host's secret store).
#
# HYGIENE: real secrets live in the PROCESS ENVIRONMENT, never in a committed
# or world-readable .env file in the served directory. The Python-verifier
# sandbox never receives these keys (scrubbed env), but a file on disk could
# still be read by a sandbox escape — so do NOT drop a populated .env next to
# the running service. A real `.env` is gitignored.

# --- provider keys (read by the engine's Config.from_env) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENROUTER_API_KEY=sk-or-REPLACE_ME

# --- deployment access gate (REQUIRED in any networked run) ---
# Shared secret testers send as the `X-Aedos-Key` header. Empty + auth-on = the
# gate fails closed (rejects everything). Set AEDOS_REQUIRE_AUTH=0 ONLY for
# purely-local dev with no network exposure.
AEDOS_DEPLOY_KEY=change-me-to-a-long-random-string
AEDOS_REQUIRE_AUTH=1

# --- CORS: browser origins allowed to call the API (CSV) ---
# Dev: the Vite server. Prod: the deployed UI origin.
AEDOS_ALLOWED_ORIGINS=http://localhost:5173

# --- engine substrate DB ---
AEDOS_DB_PATH=aedos_phase10_5.db

# --- per-session rate limit ---
AEDOS_RATE_LIMIT_REQUESTS=30
AEDOS_RATE_LIMIT_WINDOW=60
